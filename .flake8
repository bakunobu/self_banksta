run flake8[flake8]
# Exclude common service directories
exclude = 
    .git,
    __pycache__,
    venv,
    env,
    .venv,
    build,
    dist,
    *.egg-info,
    node_modules,
    .vscode,
    .pytest_cache,
    .mypy_cache,
    .tox,
    tests,
    telegram_loan_bot
    
# Set maximum line length
max-line-length = 88

# Ignore some common warnings that might be too strict
# E203: whitespace before ':' (conflicts with black)
# W503: line break occurred before a binary operator (conflicts with black)
ignore = E203, W503

# Show source of each error
show-source = true

# Show statistics at the end
statistics = true